# Must be included after .prompt as this file may derive values from the selected hierarchy

rootdays=368
intermediatedays=367
issuingdays=366
eedays=365

# Set variables based upon input
CONFIGFILES=( "blank" "G4PrivateTLS.cnf" "G4PrivateOtherLP.cnf" "G4PrivateOtherNP.cnf")
CONFIGFILE=${CONFIGFILES[$((catype))]}

genpkeyopt="-algorithm RSA -pkeyopt rsa_keygen_bits:4096"
sigopt="-sigopt rsa_padding_mode:pss -sigopt rsa_pss_saltlen:64"
reqopt="-config "$CONFIGFILE" ${sigopt} -new"
caopt="-config "$CONFIGFILE" ${sigopt} -batch -notext -rand_serial"
crlopt="-gencrl -config "$CONFIGFILE" ${sigopt}"

CA_DIR=$(grep '^CA_DIR\s*=' "$CONFIGFILE" | awk '{print $3}')
PRIVATE_DIR=$CA_DIR/private
CERT_DIR=$CA_DIR/certs
CRL_DIR=$CA_DIR/crl
CSR_DIR=$CA_DIR/csr
NEWCERTS_DIR=$CA_DIR/newcerts

issuingbasename=$(grep '^TSPBASENAME\s*=' "$CONFIGFILE" | awk '{print $3}')